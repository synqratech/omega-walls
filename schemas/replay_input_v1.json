{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "replay_input_v1.json",
  "title": "omega_replay_input_v1",
  "type": "object",
  "required": [
    "event",
    "schema_version",
    "turns"
  ],
  "properties": {
    "event": {"const": "omega_replay_input_v1"},
    "schema_version": {"type": "string"},
    "replay_id": {"type": "string"},
    "canonical_path": {"type": "string"},
    "execution": {
      "type": "object",
      "properties": {
        "state_bootstrap": {
          "type": "string",
          "enum": ["fresh_state", "reuse_state", "reset_actor_before_run"]
        }
      }
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["session_id", "actor_id", "turn_index", "user_query", "packet_items"],
        "properties": {
          "session_id": {"type": "string", "minLength": 1},
          "actor_id": {"type": "string", "minLength": 1},
          "turn_index": {"type": "integer", "minimum": 1},
          "user_query": {"type": "string", "minLength": 1},
          "packet_items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["doc_id", "source_id", "source_type", "trust", "text"],
              "properties": {
                "doc_id": {"type": "string", "minLength": 1},
                "source_id": {"type": "string", "minLength": 1},
                "source_type": {"type": "string", "minLength": 1},
                "trust": {"type": "string", "minLength": 1},
                "text": {"type": "string"},
                "language": {"type": ["string", "null"]},
                "meta": {"type": "object"}
              }
            }
          },
          "tool_requests": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tool_name"],
              "properties": {
                "tool_name": {"type": "string", "minLength": 1},
                "args": {"type": "object"},
                "session_id": {"type": "string"},
                "step": {"type": "integer", "minimum": 1}
              }
            }
          },
          "meta": {"type": "object"}
        }
      }
    },
    "expected": {"type": "object"},
    "refs": {"type": "object"}
  }
}
