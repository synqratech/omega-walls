{
  "name": "@omega-walls/openclaw-guard",
  "version": "0.1.0",
  "description": "OpenClaw Plugin SDK integration for Omega Walls trust-boundary guard",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "smoke": "node --import tsx scripts/smoke.ts",
    "smoke:local-api": "node --import tsx scripts/smoke-local-api.ts"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.8",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
