include LICENSE
include README.md
include README_PYPI.md
include pyproject.toml

recursive-include omega *.py *.yml

prune .venv
prune .venv-linux
prune .vendor
prune .vendor_pytest
prune artifacts
prune data
prune cloud
prune docs
prune enterprise
prune internal_data
prune notebooks
prune redteam
prune schemas
prune tests
prune e5-small-v2
prune multilingual-e5-small
prune deberta-v3-base

exclude API_OpenAI.txt
exclude partner_policy_pack_latest.zip
exclude partner_policy_pack_v1_20260323.zip
exclude model.safetensors
exclude tokenizer.json
exclude tokenizer_config.json
exclude vocab.json
exclude merges.txt
exclude config.json
exclude generation_config.json

global-exclude *.py[cod]
global-exclude __pycache__
global-exclude .DS_Store
